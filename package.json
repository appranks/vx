{
  "name": "@appranks/vx",
  "version": "0.0.1",
  "description": "Ephemeral observability for coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/appranks/vx.git"
  },
  "bin": {
    "vx": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "1.3.11",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
